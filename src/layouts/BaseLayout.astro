---
import Head from "../components/layout/Head.astro";
import Header from "../components/layout/Header";
import Footer from "../components/layout/Footer.astro";
import "../styles/main.scss";
---

<html lang="en">
  <Head title="Allbright Home Services" />
  <Header client:only="react" />
  <slot />
  <Footer />
  <script>
    (function () {
      // --- 1) Configure floating teaser bubble (must be BEFORE the embed script) ---
      (window as any).chatbaseConfig = {
        // show the floating teaser bubble above the launcher
        showFloatingInitialMessages: true,
        // seconds before showing the teaser (adjust as you like)
        floatingInitialMessagesDelay: 1
      };

      // Optional: also declare the standard embed config (some setups read this)
      (window as any).embeddedChatbotConfig = {
        chatbotId: "QyXsFCkhAqyBY_4aUC8XK",
        domain: "www.chatbase.co"
      };

      // --- 2) Safe pre-init stub so calls can queue before SDK is ready ---
      if (!(window as any).chatbase || (window as any).chatbase("getState") !== "initialized") {
        (window as any).chatbase = (...args: any[]) => {
          if (!(window as any).chatbase.q) (window as any).chatbase.q = [];
          (window as any).chatbase.q.push(args);
        };
        (window as any).chatbase = new Proxy((window as any).chatbase, {
          get(target, prop) {
            if (prop === "q") return (target as any).q;
            return (...args: any[]) => (target as any)(prop, ...args);
          },
        });
      }

      // --- 3) Load official embed (use attributes, not element.id) ---
      const onLoad = function () {
        const script = document.createElement("script");
        script.src = "https://www.chatbase.co/embed.min.js";
        script.defer = true;
        // ✅ Use the documented attributes Chatbase reads:
        script.setAttribute("chatbotId", "QyXsFCkhAqyBY_4aUC8XK");
        script.setAttribute("domain", "www.chatbase.co");

        // After SDK loads, set the actual initial message content
        script.onload = () => {
          (window as any).chatbase.setInitialMessages?.([
            "👋 Hi! Need pricing or help booking a cleaning? Ask me here."
          ]);
        };

        document.body.appendChild(script);
      };

      if (document.readyState === "complete") onLoad();
      else window.addEventListener("load", onLoad);
    })();
  </script>
  <div id="modal-root"></div>
</html>
