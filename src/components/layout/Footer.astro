---
import RedirectCTA from "../buttons/RedirectCTA"
---

<footer class="footer">

  <div class="footer__content">
    <div class="footer__logo">
      <a href="/" class="footer__logo-link">
        <div class="footer__logo-img">
          <img src="/allbright-logo.png" alt="Allbright Home Services Logo">
        </div>
        <div class="footer__logo-text">
          <span>ALLBRIGHT HOME SERVICES</span>
        </div>
      </a>
    </div>
  
    <div class="footer__links">
      <div class="footer__column">
        <div class="footer__contact">
          <div class="footer__email">
            <img src="/footer/icon-email.png" alt="Email">
            <span><a href="mailto:contact@allbright.com">contact@allbright.com</a></span>
          </div>
          <div class="footer__phone">
            <img src="/footer/icon-phone.png" alt="Phone">
            <span><a href="tel:+14082801234">(408) - 280 - 1234</a></span>
          </div>

        </div>
        <div class="footer__social">
          <a href="https://www.facebook.com/profile.php?id=61578145885811" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <img src="/footer/icon-fb.png" alt="Facebook">
          </a>
          <a href="https://www.instagram.com/allbrighths/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <img src="/footer/icon-ig.png" alt="Instagram">
          </a>
          <!-- Twitter icon removed -->
        </div>

        <div class="footer__cta">
          <RedirectCTA 
            href="https://book.housecallpro.com/book/All-Bright-Home-Services/38acff17233d44ec9cdc0edf4aadf395?v2=true" 
            text="Book a Free Consultation" 
            buttonClass="primary-cta"/>
        </div>
      </div>
  
      <!-- Column 1 -->
      <div class="footer__column">
        <ul class="footer__list">
          <li class="footer__item">
            <a href="/our-services/recurring-services/weekly-maid-services">Weekly Maid Services</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/recurring-services/bi-monthly-maid-services">Bi-Monthly Maid Services</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/recurring-services/monthly-maid-services">Monthly Maid Services</a>
          </li>
        </ul>
      </div>
  
      <!-- Column 2 -->
      <div class="footer__column">
        <ul class="footer__list">
          <li class="footer__item">
            <a href="/our-services/one-time-services/one-time-maid-services">One-Time Maid Services</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/one-time-services/deep-cleaning">Deep Cleaning</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/one-time-services/carpet-cleaning">Carpet Cleaning</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/one-time-services/window-washing">Window Washing</a>
          </li>
        </ul>
      </div>
  
      <!-- Column 3 -->
      <div class="footer__column">
        <ul class="footer__list">
          <li class="footer__item">
            <a href="/our-services/packages/full-bundle">Full Bundle</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/packages/carpet-bundle">Carpet Bundle</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/packages/window-bundle">Window Bundle</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/packages/carpet-and-window-bundle">Carpet and Window Bundle</a>
          </li>
        </ul>
      </div>
  
      <!-- Column 4 -->
      <div class="footer__column">
        <ul class="footer__list">
          <li class="footer__item">
            <a href="/our-services/packages/pristine-plan">Pristine Maintenance Plan</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/packages/care-plan">Care Maintenance Plan</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/packages/refresh-plan">Refresh Maintenance Plan</a>
          </li>
          <li class="footer__item">
            <a href="/our-services/packages/signature-plan">Signature Maintenance Plan</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer__copyright">
    <span>© 2025 Allbright Home Services | All Rights Reserved</span>
  </div>
</footer>
