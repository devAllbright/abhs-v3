  socialProof: [
    "5,000+ customers trust in Allbright Home Services",
    "200,000+ services completed"
  ],
  images: {
    googleLogo: "/google-logo.png",
    ratingStars: "rating-stars.svg",
    checkIcon: "/check.png",
    heroImage: "/hero-img.png"
  },

  imgClass: "--main",

  ctaAction: "redirect"
};

