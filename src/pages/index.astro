};

const faqs = [
  { question: "What is your return policy?", answer: "You can return any item within 30 days of purchase for a full refund." },
  { question: "Do you offer international shipping?", answer: "Yes, we ship to most countries worldwide. Shipping rates may vary." },
  { question: "How can I track my order?", answer: "Once your order is shipped, you will receive a tracking number via email." },
