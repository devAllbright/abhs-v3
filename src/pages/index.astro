const finalCTAData = {
  imgSrc: "/final-cta.png",
  imgAlt: "Final Call to Action",
  title: "A cleaner home, a better life!",
  brief: "Everything we do is designed to make your life easier, your home fresher, and your time more enjoyable.",
  callToActionText: "Ready to experience the difference?",
  contactText: "Contact us today!"
};

const faqs = [
  {
    question: "What types of cleaning and maintenance services do you offer?",
    answer: "We provide a complete range of residential cleaning and home maintenance services. This includes recurring house cleaning, deep/detail cleaning, carpet and tile cleaning, and move-in/move-out cleaning. We also offer exterior upkeep such as window washing, pressure washing, outdoor kitchen cleaning, gutter cleaning, and seasonal home maintenance plans."
  },
  {
    question: "How do I schedule a service?",
    answer: "Booking is simple! Call us directly to schedule your service with one of our experts, or request a free consultation to create a personalized plan that fits your home and lifestyle. We’ll help you choose the right service, pick a convenient time, and take care of the rest."
  },
  {
    question: "Are your cleaners and technicians background-checked?",
    answer: "Absolutely. All of our team members undergo background checks and professional training to ensure quality service and peace of mind."
  },
  {
    question: "Do I need to be home during the cleaning?",
    answer: "Not necessarily. Many of our clients prefer to provide access and go about their day while we take care of the cleaning. You are also welcome to stay home if you prefer. Either way, you can trust our team to respect your space and follow any special instructions you provide."
  },
  {
    question: "What areas do you serve?",
    answer: "We proudly serve the Greater Silicon Valley and South Bay area. Our service areas include Atherton, Hillsborough, Palo Alto, Los Altos, Mountain View, Sunnyvale, Santa Clara, San Jose, Saratoga, Los Gatos, and surrounding neighborhoods."
  }
];
---

<BaseLayout>
  <Hero bannerData={bannerData} client:only="react"/>
  <BenefitSection client:only="react"/>
  <WhyChooseUsSection />
  <ReviewsWidget />
  <PostCarousel posts={blogPosts} client:only="react" />
  <FAQSection faqs={faqs} />
  <FinalCTASection finalCTAData={finalCTAData} />
</BaseLayout>

<script>
  sessionStorage.setItem('serviceType', 'recurring');
    sessionStorage.setItem('primaryCta', 'Maid Services - Request a Booking');
</script>
