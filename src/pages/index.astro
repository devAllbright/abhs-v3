];

const finalCTAData = {
  imgSrc: "/final-cta.png",
  imgAlt: "Final Call to Action",
  title: "A cleaner home, a better life!",
  brief: "Everything we do is designed to make your life easier, your home fresher, and your time more enjoyable.",
  callToActionText: "Ready to experience the difference?",
  contactText: "Contact us today!",
};

const faqs = [
  {
    question: "What types of cleaning and maintenance services do you offer?",
    answer: "We provide a full range of house cleaning services—including deep cleaning, move-in/move-out cleaning, and recurring maintenance—as well as general home upkeep such as appliance cleaning, minor repairs, and seasonal maintenance tasks."
  },
  {
    question: "How do I book a cleaning or maintenance appointment?",
    answer: "Booking is easy! You can schedule a service online through our website or call us directly. Simply choose your service, pick a time that works for you, and we’ll handle the rest."
  },
  {
    question: "Are your cleaners and technicians background-checked?",
    answer: "Yes, all our team members go through thorough background checks and are fully trained professionals to ensure your home is in safe hands."
  },
  {
    question: "Do I need to be home during the service?",
    answer: "It's completely up to you. Many clients prefer to provide access and go about their day. You can trust our team to respect your space and follow any specific instructions you provide."
  },
  {
    question: "What areas do you serve?",
    answer: "We proudly serve the Greater Silicon Valley region, including the South Bay and East Bay. Our service area covers cities like San Jose, Fremont, Santa Clara, Palo Alto, Mountain View, and surrounding neighborhoods."
  }
];

---

<BaseLayout>
  <Hero bannerData={bannerData} client:only="react"/>
  <BenefitSection client:only="react"/>
  <WhyChooseUsSection />
  <ReviewsWidget />
  <PostCarousel posts={ blogPosts } client:only="react" />
  <FAQSection faqs={ faqs } />
  <FinalCTASection finalCTAData={ finalCTAData }/>
</BaseLayout>