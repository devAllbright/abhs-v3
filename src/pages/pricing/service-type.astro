---
import ServiceTypeComponent from '../../components/pricing/ServiceType'
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Select Service">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
<div class="step-section">
  <div class="step-container">
    <div class="step-title">
      <p>Service Type</p>
    </div>

    <div class="service-type">
      <ServiceTypeComponent client:only="react"></ServiceTypeComponent>
    </div>

  </div>
</div>

<style>
  *{
    margin: 0px;
    padding: 0px;
    font-family: 'Inter', sans-serif;
  }

  .step-section{
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 100vh;
    background-color: #FFF4E4;
  }

  .step-container{
    width: 1200px;
    height: 800px;
    background-color: #FBFCF8;  
  }

  .step-title{
    font-size: 36px;
    margin-top: 145px;
    font-weight: bold;
    text-align: center;
  }

  .colored{
    color: #DE9C38;
    -webkit-text-stroke: 1px black; /* For WebKit browsers */
  }

</style>
</BaseLayout>