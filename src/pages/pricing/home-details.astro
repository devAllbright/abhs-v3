---
import HomeDetailsComponent from "../../components/pricing/HomeDetails.jsx";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Home Details">
  <div class="step-section">
    <div class="step-container">
      <div class="step-title">
        <p>My Home</p>
      </div>

      <div class="home-details">
        <HomeDetailsComponent client:only="react" />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  * {
    margin: 0;
    padding: 0;
    font-family: 'Inter', sans-serif;
  }

  .step-section {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 140vh;
    background-color: #FFF4E4;
  }

  .step-container {
    width: 1200px;
    height: 800px;
    background-color: #FBFCF8;
  }

  .step-title {
    font-size: 36px;
    margin-top: 72px;
    font-weight: bold;
    text-align: center;
  }

  .colored {
    color: #DE9C38;
    -webkit-text-stroke: 1px black;
  }
</style>
