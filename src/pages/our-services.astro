---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchBar from "../components/pages/our-services/SearchBar";
import ServiceSection from "../components/pages/home/ServiceSection.astro";
import ReviewsWidget from "../components/pages/ReviewsWidget.astro";
import FAQSection from "../components/pages/home/FAQSection.astro"
import FinalCTASection from "../components/pages/home/FinalCTASection.astro";


const finalCTAData = {
  imgSrc: "/final-cta.png",
  imgAlt: "Final Call to Action",
  title: "A cleaner home, a better life!",
  brief: "Everything we do is designed to make your life easier, your home fresher, and your time more enjoyable.",
  callToActionText: "Ready to experience the difference?",
  contactText: "Contact us today!",
};

const faqs = [
  { question: "What is your return policy?", answer: "You can return any item within 30 days of purchase for a full refund." },
  { question: "Do you offer international shipping?", answer: "Yes, we ship to most countries worldwide. Shipping rates may vary." },
  { question: "How can I track my order?", answer: "Once your order is shipped, you will receive a tracking number via email." },
  { question: "What payment methods do you accept?", answer: "We accept Visa, MasterCard, PayPal, and Apple Pay." },
  { question: "Can I change my order after placing it?", answer: "Orders can be modified within 24 hours of placement by contacting support." }
]
---

<BaseLayout>
  <SearchBar client:only="react"/>
  <ServiceSection />
  <ReviewsWidget />
  <FAQSection faqs={ faqs } />
  <FinalCTASection finalCTAData={ finalCTAData }/>
</BaseLayout>

<script>
  sessionStorage.setItem('serviceType', 'other');
</script>