  <BundleAndSave bundleData={ bundleData } client:only="react"/>
  <ReviewsWidget />
  <PostCarousel posts={ blogPosts } client:only="react"/>
  <FAQSection faqs={ faqs }/>
  <FinalCTASection finalCTAData={ finalCTAData }/>

</BaseLayout>

<script>
  sessionStorage.setItem('serviceType', 'other');
