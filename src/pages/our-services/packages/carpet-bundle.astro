const faqs = [
  {
    question: "What’s included in the Carpet Bundle?",
    answer: "The Carpet Bundle combines Deep Cleaning and Carpet Cleaning in one visit. It’s a great way to refresh your entire home while also giving your carpets a professional clean—removing stains, allergens, and odors for a healthier environment."
  },
