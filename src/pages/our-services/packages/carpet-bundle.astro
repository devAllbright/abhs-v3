---

<BaseLayout title="Carpet Cleaning Bundle">
  <Hero bannerData={ bannerData } client:load/>
  <ServiceDescription descriptionData={ descriptionData }client:load/>
  <ServiceDetails serviceName= "Carpet Bundle" client:load/>
  <HowItWorks reasons={ reasonsData }/>
  <BundleAndSave bundleData={ bundleData } client:load/>
  <ReviewsWidget />
  <PostCarousel posts={ blogPosts } client:load/>
  <FAQSection faqs={ faqs }/>
  <FinalCTASection finalCTAData={ finalCTAData }/>

</BaseLayout>

<script>
  sessionStorage.setItem('serviceType', 'other');
</script>
