  <BundleAndSave bundleData={ bundleData } client:load/>
  <ReviewsWidget />
  <PostCarousel posts={ blogPosts } client:load/>
  <FAQSection faqs={ faqs }/>
  <FinalCTASection finalCTAData={ finalCTAData }/>

</BaseLayout>

